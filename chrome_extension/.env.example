# Chrome extension build config.
# Copy to chrome_extension/.env (gitignored) to override the default.

# API server the extension talks to. Inlined into dist/sidepanel.js at
# build time, so this is whatever URL the bundle will point at — there is
# no runtime override.
#
# Leave unset to default to http://localhost:8080 (matches the local
# server from `server/README.md`). Set to your deployed API before
# building for the Chrome Web Store, e.g.:
#   API_URL=https://your-api.fly.dev
#
# You can also pass it inline for one-off builds:
#   API_URL=https://your-api.fly.dev npm run build
API_URL=
