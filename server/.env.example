# LiveKit — realtime audio/video
# Use your LiveKit Cloud URL (e.g. wss://your-project.livekit.cloud).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Groq — STT (Whisper) and LLM (Llama Scout)
GROQ_API_KEY=

# ElevenLabs — TTS
ELEVEN_API_KEY=

# LemonSlice — avatar rendering
LEMONSLICE_API_KEY=

# Public base URL hosting persona portraits under `/characters/<filename>`.
# The marketing site at https://couchverse.tv already serves these (the
# landing page uses the same images), so production should point here.
# The FastAPI process also mounts the same directory at /characters/ as
# a self-hosted fallback — set to your API URL if you don't want to
# depend on the marketing site. LemonSlice Cloud fetches from its own
# servers, so `localhost` will not work.
# Leave unset to run without avatars.
AVATAR_BASE_URL=https://couchverse.tv

# PostgreSQL (Neon or local)
DATABASE_URL=

# LiveKit agent name — must match between API and agent worker.
# Use a unique name for local dev so dispatches don't collide
# with the deployed worker.
AGENT_NAME=podcast-commentary-agent-local

# PersonaConfig presets to load — comma-separated list of filenames in
# src/podcast_commentary/agent/persona_configs/ (without the `.py` extension).
# Each entry becomes one on-screen persona; the **first entry is the
# primary** (the room that owns the user mic and STT pipeline).
#
# The shipping default is `alien,cat_girl`. Other presets in persona_configs/
# (e.g. `david_sacks`) are opt-in experiments — add them here to play
# with them, but they are not part of the canonical lineup.
PERSONAS=alien,cat_girl
